# =============================================================
# EcoLoop AI - Variables d'environnement
# =============================================================
# Copier ce fichier vers .env et adapter les valeurs
# Commande : cp .env.example .env
# =============================================================

# Clé secrète JWT (à changer impérativement en production !)
JWT_SECRET=votre-cle-secrete-tres-longue-et-complexe

# Chemin vers les modèles sauvegardés
MODEL_PATH=saved_models

# URL de connexion à la base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ecoloop

# Environnement d'exécution (development, staging, production)
ENV=development

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Port de l'API
API_PORT=8000
