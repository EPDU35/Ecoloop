# === Application ===
APP_NAME=EcoLoop API
ENVIRONMENT=development          # development | staging | production
DEBUG=false
API_V1_PREFIX=/api/v1

# === Sécurité ===
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=10
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# === Base de données ===
DATABASE_URL=postgresql+asyncpg://ecoloop_user:CHANGE_ME@localhost:5432/ecoloop_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# === Redis (cache, rate limit, blacklist tokens) ===
REDIS_URL=redis://localhost:6379/0

# === CORS (liste blanche stricte, séparée par des virgules) ===
# http://localhost:5000 correspond au port fixe utilisé par `flutter run -d chrome --web-port=5000`
# (voir README Flutter) — sans ce port exact dans la liste, le navigateur bloque
# toutes les requêtes de l'app web avec une erreur CORS.
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:3001,https://app.ecoloop.ci,https://admin.ecoloop.ci

# === Hôtes de confiance ===
# 10.0.2.2 = alias réseau spécial utilisé par l'émulateur Android pour joindre
# l'hôte (voir lib/core/api_service.dart côté Flutter). Sans lui ici, l'API
# renvoie 400 "Invalid host header" à toute requête venant de l'émulateur,
# même une fois la connectivité réseau résolue.
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,api.ecoloop.ci

# === Stockage fichiers (Cloudinary) ===
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# === Webhook prestataire de paiement (mobile money) ===
PAYMENT_WEBHOOK_SECRET=CHANGE_ME

# === AI Service (microservice de classification, prédiction, anti-fraude) ===
AI_SERVICE_URL=http://localhost:8001

# === Email (Brevo / ex-Sendinblue) - 300 mails/jour gratuits ===
# Mode 1 (API HTTP) : renseigner BREVO_API_KEY (clé "xkeysib-...").
# Mode 2 (SMTP)     : renseigner SMTP_LOGIN + SMTP_PASSWORD (clé "xsmtpsib-...").
#   -> Si SMTP_LOGIN et SMTP_PASSWORD sont remplis, le mode SMTP est prioritaire.
# EMAIL_SENDER_EMAIL doit être un expéditeur/domaine VÉRIFIÉ dans Brevo.
BREVO_API_KEY=
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=CHANGE_ME            # ex: 8xxxxxx@smtp-brevo.com (onglet SMTP de Brevo)
SMTP_PASSWORD=CHANGE_ME         # clé SMTP xsmtpsib-...
EMAIL_SENDER_NAME=EcoLoop
EMAIL_SENDER_EMAIL=no-reply@ecoloop.ci
FRONTEND_URL=http://localhost:5000

# === Firebase Cloud Messaging (push notifications) ===
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# === Rate limiting ===
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute
