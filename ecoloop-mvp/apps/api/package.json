    "@fastify/swagger-ui": "4.0.1",
    "@prisma/client": "5.22.0",
    "fastify": "4.28.1",
    "fastify-type-provider-zod": "1.2.0",
    "zod": "3.23.8",
    "bcryptjs": "2.4.3",
    "date-fns": "4.1.0",
    "@ecoloop/database": "workspace:*",
    "@ecoloop/auth": "workspace:*",
    "@ecoloop/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/bcryptjs": "2.4.6",
    "typescript": "5.6.3",
