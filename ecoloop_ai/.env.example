# =============================================================
# EcoLoop AI - Variables d'environnement
# =============================================================
# Copier ce fichier vers .env et adapter les valeurs
# Commande : cp .env.example .env
# =============================================================

# Clé secrète JWT (doit correspondre à celle du backend)
JWT_SECRET=dev-secret-key-ecoloop-ai-service-do-not-use-in-prod-32chars

# Chemin vers les modèles sauvegardés
MODEL_PATH=saved_models

# URL de connexion à la base de données PostgreSQL
DATABASE_URL=postgresql+asyncpg://ecoloop_user:ecoloop_pass@localhost:5432/ecoloop_db

# Environnement d'exécution (development, staging, production)
ENV=development

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080,http://10.0.2.2:8000

# Port de l'API
API_PORT=8001

# Hôte d'écoute
API_HOST=0.0.0.0

# Taille max des images en bytes (défaut: 10 Mo)
MAX_IMAGE_SIZE=10485760

# Limite de requêtes par minute
MAX_REQUESTS_PER_MINUTE=100
