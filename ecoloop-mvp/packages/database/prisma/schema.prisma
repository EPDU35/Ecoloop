// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN_ECOLOOP
  SUPPORT_AGENT
  FINANCE_MANAGER
  AGENT_MAIRIE
  PRODUCTEUR
  COLLECTEUR
  INDUSTRIEL
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  BANNED
}

enum WasteType {
  PLASTIQUE
  PAPIER_CARTON
  VERRE
  METAL
  DECHETS_ELECTRONIQUES
  ORGANIQUES
}

enum CollecteStatus {
  EN_ATTENTE
  COLLECTEUR_ASSIGNE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum MissionStatus {
  DISPONIBLE
  ACCEPTEE
  EN_ROUTE
  ARRIVE
  EN_COURS_COLLECTE
  TERMINEE
  REFUSEE
  ANNULEE
}

enum LotStatus {
  DISPONIBLE
  RESERVE
  EN_NEGOCIATION
  VENDU
  EXPIRE
}

enum OrderStatus {
  EN_ATTENTE
  CONFIRMEE
  EXPEDIEE
  LIVREE
  RECUE
  VALIDEE
  ANNULEE
}

enum PaymentStatus {
  EN_ATTENTE
  COMPLETE
  ECHOUE
  REMBOURSE
}

enum TicketStatus {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

enum TicketPriority {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum VehicleType {
  VELO
  SCOOTER
  VOITURE
  CAMIONNETTE
  CAMION
}

enum VerificationStatus {
  EN_ATTENTE
  VALIDE
  REJETE
  EXPIRE
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  phone         String?
  avatar        String?
  role          UserRole     @default(PRODUCTEUR)
  status        UserStatus   @default(PENDING_VERIFICATION)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastLoginAt   DateTime?

  // Relations
  addresses     Address[]
  producer      Producer?
  collector     Collector?
  industrial    Industrial?
  mairie        Mairie?
  notifications Notification[]
  tickets       Ticket[]         @relation("TicketUser")
  assignedTickets Ticket[]       @relation("TicketAssigned")
  payments      Payment[]
  rewards       Reward[]
  collectes     Collecte[]       @relation("CollecteProducteur")
  collectesAsCollector Collecte[] @relation("CollecteCollecteur")
  missions      Mission[]
  lots          Lot[]
  orders        Order[]
  documents     Document[]
  activities    ActivityLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // "Domicile", "Bureau", "Entrepôt"
  street      String
  complement  String?
  postalCode  String
  city        String
  country     String   @default("France")
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([postalCode, city])
}

model Producer {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String?
  siret           String?  @unique
  activityType    String?  // "Ménage", "Commerce", "Entreprise"
  wasteVolumeEst  Float?   // Volume estimé mensuel en kg
  preferredDays   String[] // Jours préférés pour collecte
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siret])
}

model Collector {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType     VehicleType
  vehiclePlate    String         @unique
  vehicleCapacity Float          // Capacité en kg
  activityZone    String[]       // Codes postaux / zones
  isAvailable     Boolean        @default(true)
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  rating          Float          @default(5.0)
  totalCollectes  Int            @default(0)
  totalEarnings   Float          @default(0)
  verifiedAt      DateTime?
  verificationStatus VerificationStatus @default(EN_ATTENTE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  documents       Document[]
  @@index([vehiclePlate])
  @@index([verificationStatus])
}

model Industrial {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  siret           String   @unique
  activitySector  String   // "Recyclage plastique", "Papeterie", "Verrierie", etc.
  certifications  String[] // ISO, certifications environnementales
  paymentTerms    Int      @default(30) // Jours de paiement
  minOrderVolume  Float    // Volume minimum commande en kg
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siret])
}

model Mairie {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String   // Nom de la mairie / collectivité
  department      String   // Département
  region          String   // Région
  population      Int?
  wasteZones      Json?    // Zones de collecte géométriques (GeoJSON)
  adminLevel      String   @default("COMMUNE") // COMMUNE, DEPARTEMENT, REGION
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zones           Zone[]
  alerts          Alert[]
  @@index([department, region])
}

model Collecte {
  id              String         @id @default(cuid())
  producerId      String
  producer        User           @relation("CollecteProducteur", fields: [producerId], references: [id])
  collectorId     String?
  collector       User?          @relation("CollecteCollecteur", fields: [collectorId], references: [id])
  wasteType       WasteType
  estimatedWeight Float          // Poids estimé en kg
  actualWeight    Float?         // Poids réel collecté
  photos          String[]       // URLs des photos
  addressId       String
  address         Address        @relation(fields: [addressId], references: [id])
  availableFrom   DateTime       // Disponibilité début
  availableTo     DateTime       // Disponibilité fin
  status          CollecteStatus @default(EN_ATTENTE)
  collectorNotes  String?
  producerNotes   String?
  qrCode          String?        // Code QR pour validation
  qrCodeExpiresAt DateTime?
  validatedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  mission         Mission?
  weighing        Weighing?
  reward          Reward?
  traceability    Traceability?

  @@index([producerId])
  @@index([collectorId])
  @@index([status])
  @@index([createdAt])
}

model Mission {
  id              String         @id @default(cuid())
  collecteId      String         @unique
  collecte        Collecte       @relation(fields: [collecteId], references: [id], onDelete: Cascade)
  collectorId     String
  collector       User           @relation(fields: [collectorId], references: [id])
  status          MissionStatus  @default(DISPONIBLE)
  potentialEarning Float         // Gain estimé
  distance        Float?         // Distance en km
  estimatedDuration Int?        // Durée estimée en minutes
  acceptedAt      DateTime?
  startedAt       DateTime?
  arrivedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([collectorId])
  @@index([status])
}

model Weighing {
  id            String   @id @default(cuid())
  collecteId    String   @unique
  collecte      Collecte @relation(fields: [collecteId], references: [id], onDelete: Cascade)
  weight        Float    // Poids réel en kg
  photoUrl      String   // Photo de la pesée
  collectorSig  String?  // Signature collecteur (base64)
  producerSig   String?  // Signature producteur (base64)
  qrCode        String?  // QR code de validation
  validatedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([collecteId])
}

model Lot {
  id            String      @id @default(cuid())
  industrialId  String
  industrial    Industrial  @relation(fields: [industrialId], references: [id])
  wasteType     WasteType
  totalWeight   Float       // Poids total en kg
  quality       String      // "A", "B", "C" ou description
  pricePerKg    Float       // Prix au kg
  location      String      // Localisation du stock
  latitude      Float?
  longitude     Float?
  status        LotStatus   @default(DISPONIBLE)
  reservedAt    DateTime?
  reservedBy    String?     // User ID de l'industriel qui a réservé
  soldAt        DateTime?
  description   String?
  photos        String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  orders        Order[]
  @@index([industrialId])
  @@index([wasteType])
  @@index([status])
}

model Order {
  id            String       @id @default(cuid())
  lotId         String
  lot           Lot          @relation(fields: [lotId], references: [id])
  industrialId  String
  industrial    Industrial   @relation(fields: [industrialId], references: [id])
  quantity      Float        // Quantité commandée en kg
  totalPrice    Float
  status        OrderStatus  @default(EN_ATTENTE)
  deliveryDate  DateTime?
  deliveryAddress String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  delivery      Delivery?
  payment       Payment?
  traceability  Traceability?

  @@index([industrialId])
  @@index([status])
}

model Delivery {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  collectorId   String?
  collector     User?    @relation(fields: [collectorId], references: [id])
  status        String   @default("PLANIFIEE") // PLANIFIEE, EN_COURS, LIVREE, ANNULEE
  scheduledAt   DateTime?
  startedAt     DateTime?
  deliveredAt   DateTime?
  proofPhoto    String?
  recipientSig  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([collectorId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  amount        Float
  currency      String        @default("EUR")
  status        PaymentStatus @default(EN_ATTENTE)
  method        String        // "STRIPE", "VIRMENT", "ESPECES", "WALLET"
  reference     String        @unique
  description   String?
  metadata      Json?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([reference])
}

model Reward {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  collecteId    String?  @unique
  collecte      Collecte? @relation(fields: [collecteId], references: [id])
  points        Int      @default(0)
  voucherCode   String?  @unique
  voucherValue  Float?   // Valeur en euros
  voucherType   String?  // "POINTS", "BON_ACHAT", "DON"
  description   String?
  earnedAt      DateTime @default(now())
  expiresAt     DateTime?
  usedAt        DateTime?
  isUsed        Boolean  @default(false)

  @@index([userId])
  @@index([voucherCode])
}

model Traceability {
  id            String    @id @default(cuid())
  collecteId    String?   @unique
  collecte      Collecte? @relation(fields: [collecteId], references: [id])
  orderId       String?   @unique
  order         Order?    @relation(fields: [orderId], references: [id])
  wasteOrigin   String    // Origine du déchet (adresse, producteur)
  collectorId   String?
  collector     User?     @relation(fields: [collectorId], references: [id])
  industrialId  String?
  industrial    Industrial? @relation(fields: [industrialId], references: [id])
  treatmentType String    // "RECYCLAGE", "VALORISATION", "ENFOUISSEMENT"
  co2Saved      Float?    // CO2 évité en kg
  recycledWeight Float?   // Poids recyclé
  certificates  String[]  // Certificats environnementaux
  steps         Json      // Étapes de traçabilité (JSON)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([collecteId])
  @@index([orderId])
}

model Zone {
  id          String  @id @default(cuid())
  mairieId    String
  mairie      Mairie  @relation(fields: [mairieId], references: [id], onDelete: Cascade)
  name        String
  type        String  // "PRODUCTION", "COLLECTE", "SATURATION", "POINT_COLLECTE"
  geometry    Json    // GeoJSON Polygon/Point
  wasteVolume Float?  // Volume de déchets estimé
  collectorCount Int? // Nombre de collecteurs assignés
  lastCleanedAt DateTime?
  riskLevel   Int     @default(1) // 1-5
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mairieId])
  @@index([type])
}

model Alert {
  id          String   @id @default(cuid())
  mairieId    String
  mairie      Mairie   @relation(fields: [mairieId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        Zone?    @relation(fields: [zoneId], references: [id])
  type        String   // "SATURATION", "RETARD_COLLECTE", "DECHET_SAUVAGE", "PREVENTION"
  severity    Int      @default(1) // 1-5
  title       String
  message     String
  metadata    Json?
  isRead      Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([mairieId])
  @@index([isRead])
  @@index([createdAt])
}

model Ticket {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("TicketUser", fields: [userId], references: [id])
  assignedToId String?
  assignedTo  User?         @relation("TicketAssigned", fields: [assignedToId], references: [id])
  subject     String
  description String
  status      TicketStatus  @default(OUVERT)
  priority    TicketPriority @default(NORMALE)
  category    String        // "COLLECTE", "PAIEMENT", "COMPTE", "TECHNIQUE", "LITIGE"
  metadata    Json?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages    TicketMessage[]
  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([category])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model Document {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // "IDENTITY", "VEHICLE_REG", "INSURANCE", "SIRET", "CERTIFICATION"
  fileUrl       String
  fileName      String
  mimeType      String
  status        VerificationStatus @default(EN_ATTENTE)
  verifiedAt    DateTime?
  verifiedBy    String?
  rejectedReason String?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "LOGIN", "CREATE_COLLECTE", "ACCEPT_MISSION", "PAYMENT", etc.
  entityType String  // "COLLECTE", "MISSION", "ORDER", "USER", etc.
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "COLLECTE_ASSIGNEE", "MISSION_DISPONIBLE", "PAIEMENT_RECU", "ALERTE", etc.
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Settings {
  id            String   @id @default(cuid())
  key           String   @unique
  value         Json
  description   String?
  isPublic      Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String
  userId    String?
  properties Json
  timestamp DateTime @default(now())

  @@index([eventName])
  @@index([userId])
  @@index([timestamp])
}